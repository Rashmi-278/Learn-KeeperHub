# KeeperHub API keys
# Organization-scoped key (kh_...) - required for /api and MCP. Create at:
# app.keeperhub.com -> avatar -> API Keys -> Organisation -> Create New Key
ORG_KH_API_KEY=kh_your_org_key_here

# User-scoped key (wfb_...) - only fires webhook triggers. Optional.
KH_API_KEY=wfb_your_user_key_here

# Watched Safe multisig (main.mg.wg.ens.eth on Ethereum mainnet, chain id 1)
ENS_MULTISIG=0x91c32893216dE3eA0a55ABb9851f581d4503d39b

# KeeperHub org wallet (Para MPC) - fetched via get_wallet_integration
KH_ORG_WALLET=0x1e14fce10350225CEE749D4D3114d092d23668Fa

# Discord webhook URL for guardian alerts
# Discord channel -> Edit -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE/REPLACE
